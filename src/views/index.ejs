<!DOCTYPE html>
<html>
<head>
    <title>Task Manager</title>
</head>
<body>

    <h1>Task Manager - Version 2</h1>    

    <a href="/add">Add New Task</a>

    <br><br>

    <table border="1" cellpadding="10">
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Status</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>

        <% tasks.forEach(task => { %>
            <tr>
                <td><%= task.id %></td>
                <td><%= task.title %></td>
                <td><%= task.status %></td>
                <td><%= task.created_at %></td>
                <td>
                    <a href="/edit/<%= task.id %>">Edit</a>
                    |
                    <a href="/delete/<%= task.id %>">Delete</a>
                </td>
            </tr>
        <% }) %>

    </table>

</body>
</html>
