<!DOCTYPE html>
<html>
<head>
    <title>Add Task</title>
</head>
<body>

    <h1>Add New Task</h1>

    <form action="/add" method="POST">

        <label>Task Title:</label>
        <input
            type="text"
            name="title"
            placeholder="Enter task title"
            required
        >

        <br><br>

        <button type="submit">Add Task</button>

    </form>

    <br>

    <a href="/">Back to Home</a>

</body>
</html>
